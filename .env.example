# Supabase
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# SEO (used in metadata, robots.txt, sitemap.xml — set to your real deployed domain)
NEXT_PUBLIC_SITE_URL="https://www.abirabdullah.me"

# Cloudinary
CLOUDINARY_CLOUD_NAME="MY_CLOUD_NAME"
CLOUDINARY_API_KEY="MY_API_KEY"
CLOUDINARY_API_SECRET="MY_API_SECRET"

# Resend (contact form email — sign up free at resend.com, no domain
# verification needed to send to your own account email)
RESEND_API_KEY="MY_RESEND_API_KEY"

# Cloudflare Turnstile (bot protection on the contact form — free at
# dash.cloudflare.com/?to=/:account/turnstile). Site key is public
# (safe to expose), secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="MY_TURNSTILE_SITE_KEY"
TURNSTILE_SECRET_KEY="MY_TURNSTILE_SECRET_KEY"

# OpenAI (used to auto-write project-update posts from GitHub commits)
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Gemini (optional fallback — used automatically if OpenAI is
# rate-limited or out of quota. Free key at aistudio.google.com/apikey)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GitHub webhook (auto-post on push) — set this to any long random string,
# then use the SAME value as the "Secret" when adding the webhook in each
# project's GitHub repo settings (Settings -> Webhooks -> Add webhook).
# Payload URL: https://your-domain.com/api/webhooks/github
# Content type: application/json
# Events: just the push event
GITHUB_WEBHOOK_SECRET="MY_GITHUB_WEBHOOK_SECRET"

# NextAuth
NEXTAUTH_SECRET="MY_NEXTAUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Admin session (used by lib/auth.ts + middleware.ts)
# Generate a strong random value, e.g. `openssl rand -base64 32`
JWT_SECRET="MY_LONG_RANDOM_JWT_SECRET"

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin_password"
